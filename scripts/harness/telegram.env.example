# Copy to ~/.config/talens-harness/telegram.env and fill in. Read by notify_telegram.sh.
# Create a bot via @BotFather to get the token; get your chat id by messaging the bot then
# visiting https://api.telegram.org/bot<token>/getUpdates  (look for "chat":{"id":...}).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
