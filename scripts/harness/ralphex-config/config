# talens autonomous-research harness — ralphex config (tracked, version-controlled).
# Used via:  ralphex <plan> --config-dir scripts/harness/ralphex-config --tasks-only
# Precedence: CLI flags > local .ralphex/ > this --config-dir > embedded defaults.
# NOTE: no inline comments; full-line # comments only.

# --- executor: default Claude Code, autonomous ---
# (defaults to: claude --dangerously-skip-permissions --output-format stream-json --verbose)
# task_model: pinned to Opus 4.8 (heavy research executor); jury stays Codex gpt-5.5 (cross-model).
task_model = claude-opus-4-8

# --- reviews OFF: ARIS does code/research/integrity review per phase (experiment-bridge
#     Phase 2.5, auto-review-loop, experiment-audit). ralphex's own review is redundant. ---
external_review_tool = none
codex_enabled = false
finalize_enabled = false

# --- retry / timing (Q8 transient retry = 1; hung-process guards) ---
task_retry_count = 1
session_timeout = 6h
idle_timeout = 45m

# --- 5-hour usage-window handling: WAIT it out, don't fail ---
# Without wait_on_limit (>0) a usage-limit message falls through to fatal-error behavior and the
# phase is skipped/circuit-broken. With it, ralphex's retry loop sleeps wait_on_limit and re-tries,
# repeating until the window resets (run_campaign stays blocked on ralphex, so no false skip; the
# watchdog's 8h stale window covers the <=5h wait; any in-flight run_step.sh run keeps going and the
# retry re-attaches). Patterns pinned to the 5h-window messages only — admin/org limits stay fatal
# (waiting can't clear them).
wait_on_limit = 30m
claude_limit_patterns = You've hit your limit,You've hit your session limit,Claude usage limit reached
iteration_delay_ms = 2000

# --- no worktrees (Q7 fully serial; gitignored skills would vanish in a worktree anyway) ---
use_worktree = false

# --- plan lifecycle: leave the plan in place (we manage it; do not move to completed/) ---
move_plan_on_completion = false

# --- commits carry the repo's attribution trailer ---
commit_trailer = Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>

# --- notifications: single custom path -> our Telegram curl (out-of-band, works even
#     when a task session has died). Covers ralphex-level crash/complete. ---
notify_channels = custom
notify_on_error = true
notify_on_complete = true
notify_custom_script = scripts/harness/ralphex_notify.sh
